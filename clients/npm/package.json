{
  "name": "@trazo/query",
  "version": "0.1.0",
  "description": "Trazo query language for the browser/Node — parse, validate, match, and evaluate (WASM)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "query.wasm"
  ],
  "scripts": {
    "build:wasm": "make -C ../../wasm build",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "example": "npx tsx examples/basic.ts",
    "test": "npm run build:wasm && node --test test/wasm.test.mjs"
  },
  "keywords": [
    "trazo",
    "query",
    "parser",
    "wasm",
    "filter"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
